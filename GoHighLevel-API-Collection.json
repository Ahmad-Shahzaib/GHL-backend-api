      "name": "Authentication",
      "item": [
        {
          "name": "Get OAuth URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/ghl",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "ghl"]
            },
            "description": "Get the GoHighLevel OAuth authorization URL"
          },
          "response": []
        },
        {
          "name": "OAuth Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/callback?code={{authorizationCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "callback"],
              "query": [
                {
                  "key": "code",
                  "value": "{{authorizationCode}}",
                  "description": "Authorization code from GoHighLevel"
                }
              ]
            },
            "description": "Exchange authorization code for access token"
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get current authenticated user information"
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Refresh the GoHighLevel access token"
          },
          "response": []
        },
        {
          "name": "Logout",
